@page "/objects/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Blazor.Components.Shared
@using Blazor.Models
@inject IDbContextFactory<Blazor.Data.BlazorContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h2>Create new object</h2>
<hr />

<EditForm Model="Obj" OnValidSubmit="AddObject" FormName="create" Enhance>
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" role="alert" />
    <Vector3 Label="Position" Vector="Obj.Position" />
    <Vector3 Label="Size" Vector="Obj.Size" />
    <Vector3 Label="Color" Vector="Obj.Color" />

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Create</button>
        <a class="btn btn-link" href="/objects">Back to List</a>
    </div>
</EditForm>

@code {
    private Object3d Obj { get; set; } = new(); //May not be named "Object"!

    private async Task AddObject()
    {
        using var context = DbFactory.CreateDbContext();
        context.Objects.Add(Obj);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/objects");
    }
}